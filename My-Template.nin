[custom]


proxy_group=🚀 节点选择`select`.*`[]DIRECT

proxy_group=♻️ 自动选择`url-test`[]🇺🇸 美国节点`[]🇭🇰 香港节点`http://www.gstatic.com/generate_204`300,,50

proxy_group=🤖 AI服务`select`[]🚀 节点选择`[]♻️ 自动选择`[]🇺🇸 美国节点

proxy_group=💰 美股交易`select`[]🇺🇸 美国节点`[]DIRECT

proxy_group=📺 YouTube`select`[]🚀 节点选择`[]♻️ 自动选择

proxy_group=🍎 苹果服务`select`[]DIRECT`[]🚀 节点选择

proxy_group=🛡️ 广告拦截`select`[]REJECT`[]DIRECT

proxy_group=🎯 全球直连`select`[]DIRECT

proxy_group=🐟 漏网之鱼`select`[]🚀 节点选择`[]DIRECT

proxy_group=🇭🇰 香港节点`select`(HK|香港)

